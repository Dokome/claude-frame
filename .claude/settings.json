{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Grep",
      "Glob",
      "WebSearch",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm exec *)"
    ],
    "ask": [
      "Write",
      "Edit",
      "NotebookEdit",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm install)",
      "Bash(npx create-*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(docker *)",
      "Bash(kill *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  }
}
